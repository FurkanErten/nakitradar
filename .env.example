APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI sağlayıcı seçimi
# auto: Ollama -> Gemini -> OpenAI -> Yerel CFO fallback
# ollama: sadece local Ollama
# gemini: sadece Gemini API
# openai: sadece OpenAI GPT
# local/disabled: sadece yerel CFO fallback
LLM_PROVIDER=auto

# Ücretsiz local AI
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_TIMEOUT_SECONDS=60

# Google Gemini API opsiyonel
# Anahtarı Google AI Studio'dan al: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=25

# OpenAI API opsiyonel
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=25
